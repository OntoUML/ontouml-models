<https://w3id.org/ontouml-models/model/7006bcaa-039b-5a5f-aeed-7d589aafd852/> a dcat:Dataset, mod:SemanticArtefact, dcat:Resource;
    dct:isPartOf <https://w3id.org/ontouml-models/catalog/b663ca18-8085-44a7-bcfe-2c2b5ba1faa8>;
    dct:title "TRADES Ontology";
    mod:acronym "TRADES";
    dct:issued "2025"^^xsd:gYear;
    dcat:theme lcc:T;
    skos:editorialNote "Type-level ontology obtained by translating the TRADES executable metamodel into OntoUML, aiming to make explicit the domain knowledge and practices embedded in TRADES. Covers the ontology fragments that underpin TRADES capabilities discussed in the paper, including threat/mitigation specification, risk scoring, and vulnerability management.";
    dct:language "en";
    dcat:landingPage <https://github.com/UKRI-DSbD/TRADES>;
    dct:license <https://creativecommons.org/licenses/by/4.0/>;
    dct:contributor <https://dblp.org/pid/224/5770>;
    dcat:keyword "security modelling"@en,
                 "risk assessment"@en,
                 "threat assessment"@en,
                 "threat modeling"@en,
                 "risk scoring"@en,
                 "cybersecurity"@en,
                 "vulnerability management"@en;
    dct:source <https://doi.org/10.1177/15705838251394801>;
    mod:designedForTask ocmv:ConceptualClarification,
                        ocmv:OntologicalAnalysis,
                        ocmv:DecisionSupportSystem;
    ocmv:context ocmv:Research;
    ocmv:representationStyle ocmv:OntoumlStyle;
    ocmv:ontologyType ocmv:Domain;
    ocmv:storageUrl "https://github.com/OntoUML/ontouml-models/tree/master/models/shaked2025trades"^^xsd:anyURI;
    fdpo:metadataIssued "2026-06-30T20:21:13.710261Z"^^xsd:dateTime;
    fdpo:metadataModified "2026-06-30T20:21:13.710261Z"^^xsd:dateTime .

