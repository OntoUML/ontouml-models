<https://w3id.org/ontouml-models/model/shaked2025trades/> a dcat:Dataset, mod:SemanticArtefact;
    dct:title "TRADES Ontology";
    mod:acronym "TRADES";
    dct:issued "2025"^^xsd:gYear;
    dcat:theme lcc:T;
    skos:editorialNote "Type-level ontology obtained by translating the TRADES executable metamodel into OntoUML, aiming to make explicit the domain knowledge and practices embedded in TRADES. Covers the ontology fragments that underpin TRADES capabilities discussed in the paper, including threat/mitigation specification, risk scoring, and vulnerability management.";
    dct:language "en";
    dcat:landingPage <https://github.com/UKRI-DSbD/TRADES>;
    dct:license <https://creativecommons.org/licenses/by/4.0/>;
    dct:contributor <https://dblp.org/pid/224/5770>;
    mod:designedForTask ocmv:ConceptualClarification, ocmv:OntologicalAnalysis, ocmv:DecisionSupportSystem;
    ocmv:context ocmv:Research;
    dct:source <https://doi.org/10.1177/15705838251394801>.
