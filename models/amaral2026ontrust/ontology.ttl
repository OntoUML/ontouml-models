:EfQTc9GEifiaCk7Q rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Social Commitment Belief"@en;
    ontouml:description "Belief about a social commitment (of the trustee). Social commitment is a commitment of an agent A towards another agent B. As an externally dependent moment, a social commitment inheres in A and is externally dependent on B. The social commitments necessarily cause the creation of an internal commitment in A. Also, associated to this internal commitment, a social claim of B towards A is created. Commitments and claims always form a pair that are about a unique propositional content."@en;
    ontouml:stereotype ontouml:subkind;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
<https://w3id.org/ontouml-models/model/amaral2026ontrust/IPyTc9GEifiaCk7.> rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Social Trust"@en;
    ontouml:description "A specialization of ground trust in which the trustee is an agent. The intention belief is specific to this type of trust, as in this case the trustee is a cognitive agent endowed with goals. Intention belief is a belief about an intention of the trustee. The trustor believes that the trustee intends to perform a desired action or exhibit an expected behavior."@en;
    ontouml:stereotype ontouml:subkind;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
<https://w3id.org/ontouml-models/model/amaral2026ontrust/dWYHc9GEifiaCk.X> rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Weak Trust"@en;
    ontouml:description "A specialization of social trust in which the trustor has the belief that the trustee has a commitment to goal c, which the trust relation is about."@en;
    ontouml:stereotype ontouml:subkind;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:Gpjnc9GEifiaClC4 rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Trusted Delegation"@en;
    ontouml:description "Trusted delegation accounts for trust relations in which the trustor delegates the goal of the trust relation to the trustee. It is a social relator, grounded on Weak Trust, which mediates a delegation relation between the trustor (the delegator) and the trustee (the delegatee)."@en;
    ontouml:stereotype ontouml:relator;
    ontouml:restrictedTo ontouml:relator;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
