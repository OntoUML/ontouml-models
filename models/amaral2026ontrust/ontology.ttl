<https://w3id.org/ontouml-models/model/amaral2026ontrust/3WKls9GEifiaChNP> rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Agent"@en;
    ontouml:description "In UFO-C, an agent is a substantial that creates actions and to which we can ascribe mental states (intentional moments). Agents can be physical (e.g., a person) or social (e.g., an organization). A distinction is made between human agent and artificial agent (both subkinds of physical agent), to differentiate human agents from software (or hardware) agents."@en;
    ontouml:stereotype ontouml:category;
    ontouml:restrictedTo ontouml:functionalComplex;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:dGqls9GEifiaChNa rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Object"@en;
    ontouml:description "In UFO-C, an object is a substantial unable to perceive events or to have intentional moments. Objects can also be further categorized into physical (e.g., a book, a car) and social objects (e.g., money, language)."@en;
    ontouml:stereotype ontouml:category;
    ontouml:restrictedTo ontouml:functionalComplex;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:oyZNs9GEifiaCiH5 rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Intention"@en;
    ontouml:description "Intentions (or internal commitments) are mental moments that express desired states of affairs for which the agent commits to pursuing directly or indirectly by pursuing the coming about of a certain state of affairs (e.g., Mary�s intention of paying a bill using an internet banking system). The propositional content of an intention is a goal. Intentions cause the agent to perform actions, which are intentional events, i.e., events that have the specific purpose of satisfying some intention.  "@en;
    ontouml:stereotype ontouml:mode;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:MX2js9GEifiaCiVR rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Belief"@en;
    ontouml:description "Beliefs are mental moments that have a propositional content that agents consider to be true. They can be justified by situations in reality. Examples include my belief that Rome is the Capital of Italy, and the belief that the Moon orbits the Earth.  "@en;
    ontouml:stereotype ontouml:mode;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:ISFzs9GEifiaCjbd rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Mental Moment"@en;
    ontouml:description "Mental moments refer to the capacity of some properties of certain individuals to refer to potential situations of reality. A Mental Moment is existentially dependent on a particular Agent, being an inseparable part of its mental state. Examples of mental moments include perceptions, beliefs, desires and intentions."@en;
    ontouml:stereotype ontouml:category;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
:AFZ3S9GGAqACKRP0 rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Desire"@en;
    ontouml:description "Mental moment that expresses the will of an agent towards a possible situation (e.g., a desire that Brazil wins the next World Cup)."@en;
    ontouml:stereotype ontouml:mode;
    ontouml:restrictedTo ontouml:intrinsicMode;
    ontouml:isAbstract "false"^^xsd:boolean;
    ontouml:isDerived "false"^^xsd:boolean;
    ontouml:isExtensional "false"^^xsd:boolean;
    ontouml:isPowertype "false"^^xsd:boolean;
    ontouml:order "1"^^xsd:positiveInteger.
<https://w3id.org/ontouml-models/model/amaral2026ontrust/6Hl3S9GGAqACKRQH> rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Perception"@en;
