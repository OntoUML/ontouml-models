:XZ3gcTGGAqAAHiuX rdf:type ontouml:Class;
    ontouml:project :AlTKk9GEifiaCg9N;
    ontouml:name "Agreement"@en;
    ontouml:description "A social relator that mediates a relation between two or more individuals ?that play different roles in the relation. The agreement is the mereological sum of all social commitments and claims that inhere in the corresponding individuals.  "@en;
    ontouml:stereotype ontouml:relator;
